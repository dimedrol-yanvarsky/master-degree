# HTTP
HTTP_ADDRESS=:8080
# Адрес SPA, куда сервер возвращает пользователя после внешнего входа (OAuth).
FRONTEND_URL=http://localhost:3000

# MongoDB (the data-access adapter is wired, but no collections are bound yet,
# so the server still starts without a running database)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=fuzzy_psychology

# Security / access control (ТЗ part 3)
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
BCRYPT_COST=12
MAX_LOGIN_ATTEMPTS=5

# Yandex OAuth2 (внешний вход). Пустые ClientID/Secret => провайдер выключен:
# эндпоинты /auth/oauth/yandex/* вернут «not configured», сервер не падает.
# Создать приложение: https://oauth.yandex.ru/client/new (Login API: доступ к
# адресу почты). Redirect URI должен совпадать со значением ниже.
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/yandex/callback

# SMTP (оповещение специалистов о новой вершине графа).
# Для Gmail нужен пароль приложения, не обычный пароль от аккаунта:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=golubevdv2003@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_FROM=golubevdv2003@gmail.com

# HTTPS email transport (works when outbound SMTP ports are blocked).
# Requires a verified sender/domain in Resend.
# EMAIL_TRANSPORT=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=Lumen <notify@your-domain.example>

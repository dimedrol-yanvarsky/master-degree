# HTTP
HTTP_ADDRESS=:8080
# Адрес SPA, куда сервер возвращает пользователя после внешнего входа (OAuth).
FRONTEND_URL=http://localhost:3000

# MongoDB (the data-access adapter is wired, but no collections are bound yet,
# so the server still starts without a running database)
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=fuzzy_psychology

# Security / access control (ТЗ part 3)
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
BCRYPT_COST=12
MAX_LOGIN_ATTEMPTS=5

# Yandex OAuth2 (внешний вход). Пустые ClientID/Secret => провайдер выключен:
# эндпоинты /auth/oauth/yandex/* вернут «not configured», сервер не падает.
# Создать приложение: https://oauth.yandex.ru/client/new (Login API: доступ к
# адресу почты). Redirect URI должен совпадать со значением ниже.
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/yandex/callback

# SMTP (оповещение специалистов о новой вершине графа). Пустые HOST/FROM =>
# письма пишутся в лог сервера вместо реальной отправки (безопасный фоллбэк).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
